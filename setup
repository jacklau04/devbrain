#!/usr/bin/env bash
# devbrain — one-command installer (single entrypoint).
#
#   git clone --depth 1 https://github.com/TheWeiHu/devbrain.git ~/.claude/skills/devbrain \
#     && cd ~/.claude/skills/devbrain && ./setup
#
# This is a thin front-end over scripts/install.sh (the proven machine wiring:
# capture hooks, launchd flusher, skills, settings.json, CLAUDE.md block). It adds
# the friendly bits install.sh assumes you've already done:
#   • install the gbrain engine (via bun) + a local brain
#   • pick where the brain lives (prompt; default ~/devbrain-data; create if missing)
#   • remind you to set an OpenAI key for semantic search
# then hands off to scripts/install.sh for the actual wiring.
#
# Idempotent and reversible — re-run any time; tear down with scripts/uninstall.sh.
#
# Override paths:
#   DEVBRAIN_DATA=~/somewhere ./setup                      # where prompts/brain live
#   DEVBRAIN_DATA_REMOTE=git@host:you/data.git ./setup     # clone YOUR existing private brain
#   DEVBRAIN_GIT_NAME / DEVBRAIN_GIT_EMAIL                  # identity for data-repo commits
#   DEVBRAIN_NIGHTSHIFT=0 ./setup                          # skip nightshift (installed by default)
#   ./setup --with-gbrain | --without-gbrain               # opt in/out of the optional gbrain engine
#   DEVBRAIN_GBRAIN=1 ./setup                              # same, via env (1/yes install · 0/no skip)
#   ./setup --open | --no-open                             # force / suppress opening the dashboard at the end
#   DEVBRAIN_OPEN_DASHBOARD=1 ./setup                      # same, via env (1 open · 0 skip; default: open when interactive/npm)
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DATA="${DEVBRAIN_DATA:-$HOME/devbrain-data}"
VERSION="$(cat "$REPO/VERSION" 2>/dev/null || echo unknown)"

# `./setup --version` / `-V` prints the version and exits (before any wiring).
case "${1:-}" in
  --version|-V) echo "devbrain $VERSION"; exit 0 ;;
esac

# Parse our own flags (gbrain opt-in/out, and whether --yes was passed) OUT of the
# arg list; everything else is forwarded to install.sh untouched. GBRAIN_CHOICE:
# 1/yes -> install · 0/no -> skip · "" -> undecided (prompt [Y/n] in a TTY, else
# take the default and install). An env DEVBRAIN_GBRAIN seeds it; a flag overrides it.
GBRAIN_CHOICE="${DEVBRAIN_GBRAIN:-}"; OPEN_CHOICE="${DEVBRAIN_OPEN_DASHBOARD:-}"; ASSUME_YES=0; FWD=()
for arg in "$@"; do
  case "$arg" in
    --with-gbrain|--gbrain)        GBRAIN_CHOICE=1 ;;
    --without-gbrain|--no-gbrain)  GBRAIN_CHOICE=0 ;;
    --open|--open-dashboard)       OPEN_CHOICE=1 ;;
    --no-open|--no-open-dashboard) OPEN_CHOICE=0 ;;
    --yes|-y)                      ASSUME_YES=1; FWD+=("$arg") ;;
    *)                             FWD+=("$arg") ;;
  esac
done

say()  { printf '\033[1;36m▸\033[0m %s\n' "$*"; }
ok()   { printf '  \033[32m✓\033[0m %s\n' "$*"; }
warn() { printf '  \033[33m!\033[0m %s\n' "$*"; }

# Pick the data home. Precedence: $DEVBRAIN_DATA > interactive prompt > default.
# The prompt fires ONLY in a real terminal ([ -t 0 ]). Non-interactive runs —
# Claude Code's Bash tool, `curl | bash`, CI — have no TTY, so they skip it and
# take the default (~/devbrain-data). Set $DEVBRAIN_DATA to choose the path there.
if [ -z "${DEVBRAIN_DATA:-}" ] && [ -t 0 ]; then
  printf 'Where should devbrain store prompts + brain? [%s]: ' "$DATA"
  read -r reply || reply=""
  [ -n "$reply" ] && DATA="${reply/#\~/$HOME}"
fi

# macOS TCC guard: LaunchAgents (the flusher) are denied access to ~/Desktop,
# ~/Documents, ~/Downloads ("Operation not permitted"), which silently breaks
# auto-sync. Steer the data home outside those.
case "$DATA" in
  "$HOME/Desktop/"*|"$HOME/Documents/"*|"$HOME/Downloads/"*)
    warn "$DATA is under a macOS-protected folder (Desktop/Documents/Downloads) —"
    warn "the launchd flusher is denied access there, silently breaking auto-sync."
    if [ -t 0 ]; then
      printf 'Use ~/devbrain-data instead? [Y/n]: '
      read -r yn || yn=""
      case "$yn" in [Nn]*) ;; *) DATA="$HOME/devbrain-data" ;; esac
    else
      warn "Set DEVBRAIN_DATA to a path outside those folders and re-run."
    fi
    ;;
esac

say "devbrain setup ($VERSION)"
echo "  repo: $REPO"
echo "  data: $DATA"
echo

# ── 1. Prerequisites ────────────────────────────────────────────────────────
say "Checking prerequisites"
need=0
for bin in git python3; do
  if command -v "$bin" >/dev/null 2>&1; then ok "$bin"; else warn "$bin missing (required)"; need=1; fi
done
[ "$need" = 0 ] || { echo; warn "Install the missing required tools and re-run."; exit 1; }
echo

# ── 2. gbrain engine (OPTIONAL accelerator — installed by DEFAULT, opt-out) ────
# gbrain is NOT required: the brain pages live on disk as markdown and stay fully
# searchable without it via `devbrain brain search/get` (offline grep). gbrain adds
# ranked + semantic search on top, so setup installs it BY DEFAULT (like nightshift)
# via `bun add -g gbrain` — a global change outside devbrain's own footprint. Opt out
# with --without-gbrain / DEVBRAIN_GBRAIN=0, or answer N at the prompt. The TTY prompt
# still fires (default Yes) so interactive users get a say; non-interactive runs (CI,
# `curl | bash`, --yes) take the default and install — set DEVBRAIN_GBRAIN=0 to skip.
say "gbrain engine (optional)"
# An EXPLICIT opt-out (--without-gbrain / DEVBRAIN_GBRAIN=0) means "leave gbrain alone
# this run" — even if it's already on PATH (installed for another project, or in CI).
# So gate not just the install but the init + index rebuild on it; otherwise the opt-out
# would be half-honored (we'd still `gbrain init`/`embed` against a pre-existing engine).
GBRAIN_OPTOUT=0; [ "$GBRAIN_CHOICE" = 0 ] && GBRAIN_OPTOUT=1
if [ "$GBRAIN_OPTOUT" = 1 ]; then
  ok "skipping gbrain (opted out) — offline 'devbrain brain search/get' works with zero engine."
elif command -v gbrain >/dev/null 2>&1; then
  ok "gbrain present ($(gbrain --version 2>/dev/null | head -1))"
else
  want="$GBRAIN_CHOICE"
  if [ -z "$want" ]; then
    if [ -t 0 ] && [ "$ASSUME_YES" = 0 ]; then
      echo "  gbrain adds ranked + semantic search. It installs globally via 'bun add -g gbrain'"
      echo "  (uninstall won't remove it). Decline and offline 'devbrain brain' search still works."
      printf '  Install gbrain now? [Y/n]: '
      read -r yn || yn=""
      case "$yn" in [Nn]*) want=0 ;; *) want=1 ;; esac
    else
      want=1   # undecided + no TTY (or --yes): take the default (install); DEVBRAIN_GBRAIN=0 opts out
    fi
  fi
  case "$want" in
    1|y|yes|true)
      if command -v bun >/dev/null 2>&1; then
        warn "installing gbrain via bun (global) ..."
        if bun add -g gbrain >/dev/null 2>&1 && command -v gbrain >/dev/null 2>&1; then
          ok "installed gbrain ($(gbrain --version 2>/dev/null | head -1))"
        else
          warn "install failed — fine, offline 'devbrain brain' search still works."
        fi
      else
        warn "bun not found — install it (https://bun.sh), then 'bun add -g gbrain'."
      fi ;;
    *)
      ok "skipping gbrain — offline 'devbrain brain search/get' works with zero engine."
      warn "Want ranked/semantic search later?  bun add -g gbrain  (then 'devbrain rebuild')." ;;
  esac
fi
if [ "$GBRAIN_OPTOUT" != 1 ] && command -v gbrain >/dev/null 2>&1; then
  gbrain init --pglite >/dev/null 2>&1 && ok "local brain ready (PGLite)" || warn "could not init brain (non-fatal)"
  # Embeddings (semantic search) want an OpenAI key — optional but recommended.
  key="${OPENAI_API_KEY:-}"
  if [ -z "$key" ]; then
    k="$(gbrain config get openai_api_key 2>/dev/null || true)"
    case "$k" in sk-*|*[A-Za-z0-9]*) [ "${k#*not found}" = "$k" ] && key="$k" ;; esac
  fi
  if [ -n "$key" ]; then
    ok "OpenAI key detected — semantic search enabled"
  else
    warn "No OpenAI key — search will be keyword + graph only (no semantic ranking)."
    warn "Recommended:  gbrain config set openai_api_key sk-...   (or export OPENAI_API_KEY=sk-...)"
    warn "Embeddings cost pennies; the key stays local in ~/.gbrain/config.json."
  fi
fi
echo

# ── 3. Data repo (the source of truth) — scripts/install.sh requires it to exist ──
say "Data repo"
if [ -d "$DATA/.git" ]; then
  ok "exists: $DATA"
elif [ -n "${DEVBRAIN_DATA_REMOTE:-}" ]; then
  git clone "$DEVBRAIN_DATA_REMOTE" "$DATA" && ok "cloned $DEVBRAIN_DATA_REMOTE -> $DATA"
else
  mkdir -p "$DATA/projects"
  git -C "$DATA" init -q
  printf '*.pglite\n.DS_Store\n' > "$DATA/.gitignore"
  printf '# devbrain-data\n\nPrivate prompt log + brain. Source of truth — never lose it.\n' > "$DATA/README.md"
  git -C "$DATA" add -A
  git -C "$DATA" -c user.name="${DEVBRAIN_GIT_NAME:-devbrain}" -c user.email="${DEVBRAIN_GIT_EMAIL:-devbrain@localhost}" commit -qm "init devbrain-data" || true
  ok "initialized fresh data repo at $DATA"
fi
echo

# ── 4. Hand off to the machine-wiring installer ─────────────────────────────
say "Wiring this machine (scripts/install.sh)"
# Forward component flags (--with/--without/--only/--yes) straight through — but NOT
# our own --with-gbrain/--without-gbrain, which we already consumed into FWD above.
# Don't inject a DEVBRAIN_NIGHTSHIFT default here — install.sh owns the default (on);
# a user-set value is already in the environment and inherited by the child.
DEVBRAIN_DATA="$DATA" "$REPO/scripts/install.sh" ${FWD[@]+"${FWD[@]}"}
echo
if [ "$GBRAIN_OPTOUT" != 1 ] && command -v gbrain >/dev/null 2>&1; then
  say "Build the brain index"
  DEVBRAIN_DATA="$DATA" "$REPO/scripts/rebuild-brain.sh" || true
  echo
fi

# ── 5. Open the dashboard ────────────────────────────────────────────────────
# Land the user on the browser control plane (`devbrain queue` — the Board ·
# Nightshift · Profile dashboard) right after a successful install, so devbrain
# has a face on day one instead of being an invisible set of hooks. The server is
# launched detached (it keeps serving on http://127.0.0.1:8799/ and pops your
# browser itself); closing the tab + the process stops it.
#
# Decision (OPEN_CHOICE): 1 -> open · 0 -> skip · "" -> open when this is a real
# terminal OR when invoked via npm (`npx getdevbrain install`, which exports
# DEVBRAIN_FROM_NPM=1) — but NOT under CI, which has no browser. The npm path
# can fire even when stdout is not a TTY, so gate it on an empty $CI to keep
# headless/automated installs quiet. Override with --open / --no-open or
# DEVBRAIN_OPEN_DASHBOARD=1/0.
WANT_OPEN=0
case "$OPEN_CHOICE" in
  1) WANT_OPEN=1 ;;
  0) WANT_OPEN=0 ;;
  *) { [ -t 1 ] || { [ "${DEVBRAIN_FROM_NPM:-}" = 1 ] && [ -z "${CI:-}" ]; }; } && WANT_OPEN=1 ;;
esac
if [ "$WANT_OPEN" = 1 ]; then
  say "Opening the dashboard"
  # Prefer the stable installed CLI (its dashboard.html outlives npm's throwaway
  # cache dir); fall back to this checkout's copy.
  DB_CLI="$HOME/.claude/hooks/devbrain"
  [ -x "$DB_CLI" ] || DB_CLI="$REPO/scripts/devbrain"
  mkdir -p "$DATA/projects" 2>/dev/null || true   # queue.py refuses to start without it
  if command -v nohup >/dev/null 2>&1; then
    DEVBRAIN_DATA="$DATA" nohup "$DB_CLI" queue >/dev/null 2>&1 </dev/null &
  else
    DEVBRAIN_DATA="$DATA" "$DB_CLI" queue >/dev/null 2>&1 </dev/null &
  fi
  disown 2>/dev/null || true
  ok "dashboard starting — it opens your browser (re-open later: devbrain queue)"
  echo
else
  say "Dashboard"
  ok "open the control plane anytime:  devbrain queue   (Board · Nightshift · Profile)"
  echo
fi

say "Done. Restart Claude Code to load /continue and /distill; restart Codex to pick up hooks/AGENTS.md."
