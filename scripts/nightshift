#!/usr/bin/env bash
# nightshift — autonomous overnight loop for devbrain. One verb, no path-pasting.
# Run it through the devbrain CLI:  devbrain nightshift <verb>
#
#   start [REPO] [opts]       launch the fleet (forever) + open the dashboard
#                             (add --no-watch to skip auto-opening it, e.g. headless/cron)
#                             (add --only ID,ID to run ONLY those tasks then stop — no new
#                              tasks; or just drag a selection onto the 🌙 in the dashboard)
#   watch                     (re)open the live browser dashboard
#   status                    quick text status
#   review                    held tasks + why (need you) + what to do
#   release <id>              un-hold a task (after you provide its dep)
#   approve <id>  (alias: go) greenlight: let the fleet do its downloads/installs/network unattended
#   drop <id>                 discard a held task (won't-do)
#   say <i> <msg…>            steer worker i        (--tmux only)
#   attach <i>                drop into worker i's session (--tmux only)
#   stop                      stop the fleet + dashboard
#
# Backends — how each worker runs claude (chosen at `start`):
#   headless  (DEFAULT) — one `claude -p` per turn. The process IS the turn, so
#             there's no tmux, no turn-marker hook, and no screen-scraping: simplest
#             and most robust. Runs under your Claude Code subscription. Use this.
#   --tmux    (fallback) — persistent interactive sessions you can attach + steer.
#             Kept for ONE reason: if Anthropic ever bills `claude -p` separately
#             from your subscription (per-token / API instead of under the plan),
#             ordinary interactive sessions keep workers on the subscription. Today
#             both bill the same, so headless wins.   devbrain nightshift start <repo> --tmux
#
# REPO is remembered after `start`, so later verbs need no argument.
set -uo pipefail
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"; DIR="$(cd "$(dirname "$SELF")" && pwd)"
ME="devbrain nightshift"   # the only supported invocation — surfaced in user-facing hints below
CONF="$HOME/.config/nightshift"; mkdir -p "$CONF"

save_repo() { printf '%s\n' "$1" > "$CONF/repo"; }
resolve_repo() {  # $1 optional explicit repo
  local r="${1:-}"
  [ -n "$r" ] && [ -d "$r" ] && { (cd "$r" && pwd); return; }
  [ -f "$CONF/repo" ] && { cat "$CONF/repo"; return; }
  echo ""; }

# Record/erase this run in the data repo so the multi-project queue dashboard can link
# to THIS monitor. The dashboard keys projects by <owner>__<repo>, not by checkout path,
# so the run advertises its own port via projects/<key>/nightshift-run.json. The
# dashboard probes that port for liveness, so a leftover file is harmless.
data_project_dir() {  # $1 repo → projects/<owner>__<repo> dir, or empty if unresolvable
  local repo="$1" DATA="${DEVBRAIN_DATA:-$HOME/devbrain-data}" PK="" key=""
  for c in "$HOME/.claude/hooks/devbrain-project-key.sh" "$DIR/../hooks/project-key.sh"; do
    [ -f "$c" ] && { PK="$c"; break; }; done
  [ -n "$PK" ] || return 0
  . "$PK"; key="$(devbrain_project_key "$repo")"
  [ -d "$DATA/projects/$key" ] && printf '%s\n' "$DATA/projects/$key"; }
register_run()   { local d; d="$(data_project_dir "$1")"; [ -n "$d" ] && printf '{"port":%s,"repo":"%s"}\n' "$2" "$1" > "$d/nightshift-run.json"; }
unregister_run() { local d; d="$(data_project_dir "$1")"; [ -n "$d" ] && rm -f "$d/nightshift-run.json"; }

cmd="${1:-help}"; shift 2>/dev/null || true
case "$cmd" in
  start)
    repo=""; case "${1:-}" in /*|./*|~*) repo="$1"; shift;; esac
    repo="$(resolve_repo "$repo")"; [ -n "$repo" ] || { echo "nightshift: pass a repo: $ME start <path>" >&2; exit 1; }
    save_repo "$repo"
    # which backend did they pick? default headless `claude -p`, --tmux to opt out.
    # also: auto-open the dashboard unless --no-watch (e.g. headless/cron runs).
    mode=headless; watch=1; oargs=()
    for a in "$@"; do case "$a" in
      --tmux) mode=tmux; oargs+=("$a");;
      --headless) mode=headless; oargs+=("$a");;
      --no-watch) watch=0;;
      --watch) watch=1;;
      *) oargs+=("$a");;
    esac; done
    if pgrep -f "nightshift-orchestrate.sh --repo $repo" >/dev/null 2>&1; then echo "already running on $repo"; exit 0; fi
    nohup "$DIR/nightshift-orchestrate.sh" --repo "$repo" ${oargs[@]+"${oargs[@]}"} >/dev/null 2>&1 &
    orch_pid=$!
    # The orchestrator is detached, so a fail-fast exit (e.g. no python satisfies
    # requires-python, or the base won't install — the green-gate preflight) would die
    # silently. Give it a beat, then if it's already gone, surface WHY from its log.
    sleep 2
    if ! kill -0 "$orch_pid" 2>/dev/null && ! pgrep -f "nightshift-orchestrate.sh --repo $repo" >/dev/null 2>&1; then
      echo "🌙 nightshift FAILED to start on $repo — the orchestrator exited immediately:" >&2
      tail -n 6 "$repo/.nightshift/orchestrator.log" 2>/dev/null | sed 's/^/   /' >&2
      exit 1
    fi
    # Surface the backend + WHY right here, where the choice is made.
    if [ "$mode" = tmux ]; then
      echo "🌙 nightshift started on $repo  ·  backend: interactive tmux"
      echo "   why --tmux (the fallback): kept for ONE case — if Anthropic ever bills"
      echo "      \`claude -p\` separately from your Claude Code subscription (per-token / API"
      echo "      instead of under the plan), ordinary interactive sessions keep workers on"
      echo "      the subscription. Today both bill the same, so headless is simpler + better."
      echo "      (bonus: \`$ME attach <i>\` to watch/steer a worker live.)"
    else
      echo "🌙 nightshift started on $repo  ·  backend: headless (claude -p)  [default]"
      echo "   why -p: each turn is one \`claude -p\` — the process IS the turn, so there's no"
      echo "      tmux, no turn-marker hook, no screen-scraping. Simplest + most robust, and"
      echo "      it runs under your Claude Code subscription."
      echo "   not -p? add --tmux (run \`$ME\` with no args for when you'd want that)."
    fi
    if [ "$watch" = 1 ]; then
      echo "   opening dashboard…"
      "$SELF" watch "$repo"
    else
      echo "   watch it:  $ME watch   (auto-open skipped: --no-watch)"
    fi
    ;;
  watch)
    repo="$(resolve_repo "${1:-}")"; [ -n "$repo" ] || { echo "nightshift: no repo — run '$ME start <path>' first" >&2; exit 1; }
    save_repo "$repo"; mkdir -p "$repo/.nightshift"
    # The run monitor lives INSIDE the queue dashboard now (no separate dashboard/server).
    # This loop just keeps <repo>/.nightshift/status.json fresh; `devbrain queue` reads it
    # and shows a 🌙 Nightshift toggle for this project. Idempotent.
    if ! { [ -f "$repo/.nightshift/.emit.pid" ] && kill -0 "$(cat "$repo/.nightshift/.emit.pid")" 2>/dev/null; }; then
      # rc 3 = status.py saying "fleet stopped >10 min ago": retire the loop + pidfile so a
      # run that winds down on its own (fixed-set) can't leave this emitting forever.
      nohup bash -c 'while :; do python3 "'"$DIR"'/nightshift-status.py" "'"$repo"'" 2>/dev/null; [ "$?" -eq 3 ] && break; sleep 2; done; rm -f "'"$repo"'/.nightshift/.emit.pid"' >/dev/null 2>&1 &
      echo $! > "$repo/.nightshift/.emit.pid"
    fi
    python3 "$DIR/nightshift-status.py" "$repo" 2>/dev/null     # seed once
    qport="${DEVBRAIN_QUEUE_PORT:-8799}"
    register_run "$repo" "$qport"                              # makes the 🌙 toggle appear
    # Reap a FOREIGN queue squatting our port. If something answers but it's a devbrain queue
    # pointed at a DIFFERENT $DEVBRAIN_DATA (a stale server from another session/workspace), it
    # serves a dead dashboard for our run — kill it so we bind a fresh one. We only reap on a
    # positively-identified data-dir mismatch, so a legitimately-shared queue is never touched.
    if curl -fsS "http://127.0.0.1:$qport/api/todos" >/dev/null 2>&1; then
      DATA="${DEVBRAIN_DATA:-$HOME/devbrain-data}"
      mine="$(python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "$DATA" 2>/dev/null)"
      # Emit a path ONLY when whoami positively identifies a devbrain queue with a non-empty
      # data dir — anything else stays "" so we never reap an unrelated service that merely
      # answers on the port. (os.path.realpath("") returns the CWD, not "", so the empty-data
      # case must be excluded explicitly before calling realpath.)
      theirs="$(curl -fsS "http://127.0.0.1:$qport/api/whoami" 2>/dev/null \
                | python3 -c 'import json,os,sys
try:
    w = json.load(sys.stdin); d = w.get("data", "")
    print(os.path.realpath(d) if (w.get("server") == "devbrain-queue" and d) else "")
except Exception:
    print("")' 2>/dev/null)"
      if [ -n "$theirs" ] && [ "$theirs" != "$mine" ]; then
        echo "🌙 a foreign devbrain queue (data=$theirs) is squatting port $qport — reaping it"
        for pid in $(lsof -ti "tcp:$qport" 2>/dev/null); do kill "$pid" 2>/dev/null || true; done
        sleep 1
      fi
    fi
    if ! curl -fsS "http://127.0.0.1:$qport/api/todos" >/dev/null 2>&1; then   # launch queue if needed
      dbcmd="$(command -v devbrain 2>/dev/null || echo "$HOME/.claude/hooks/devbrain")"
      nohup "$dbcmd" queue --no-open --port "$qport" >/dev/null 2>&1 &
      sleep 1
    fi
    key="$(basename "$(data_project_dir "$repo" 2>/dev/null)" 2>/dev/null)"
    url="http://127.0.0.1:$qport/?project=$key"
    # NIGHTSHIFT_NO_OPEN: register the run + emit loop without popping a tab — used when the
    # launch is triggered from the dashboard itself (drag-to-🌙), which is already open.
    if [ "${NIGHTSHIFT_NO_OPEN:-0}" = 1 ]; then :
    elif command -v open >/dev/null 2>&1; then open "$url"; else echo "open: $url"; fi
    echo "🌙 dashboard → $url  (queue + nightshift monitor — toggle 🌙 Nightshift)"
    ;;
  status)
    repo="$(resolve_repo "${1:-}")"; [ -n "$repo" ] || { echo "no repo set" >&2; exit 1; }
    python3 "$DIR/nightshift-status.py" "$repo" 2>/dev/null
    python3 - "$repo/.nightshift/status.json" <<'PY'
import json,sys
try: d=json.load(open(sys.argv[1]))
except Exception: print("no status yet"); sys.exit()
q=d.get("queue",{}); p=d.get("parked",[])
print(f"🌙 {d.get('project')}  ·  {'running' if d.get('running') else 'STOPPED'}")
print(f"   queue: {q.get('open',0)} open · {q.get('done',0)} merged · {q.get('review',0)} in review")
for w in d.get("workers",[]): print(f"   w{w['i']}: {w['state']:<7} {w['task']}")
if p: print(f"   ⚠ {len(p)} HELD — need you: {', '.join(p)}  (nightshift review)")
PY
    ;;
  review)
    repo="$(resolve_repo "${1:-}")"; [ -n "$repo" ] || { echo "no repo set" >&2; exit 1; }
    TODO="$HOME/.claude/hooks/devbrain-todo.sh"; [ -x "$TODO" ] || TODO="$DIR/todo.sh"
    echo "== held — need you (provision the dep + release, or drop) =="
    for id in $( ( cd "$repo" && "$TODO" list held 2>/dev/null ) | grep -oE '[0-9]{4}-[a-z0-9-]+'); do
      reason="$( ( cd "$repo" && "$TODO" show "$id" 2>/dev/null ) | sed -n 's/^reason:[[:space:]]*//p' | head -1)"
      printf '  %s\n      %s\n' "$id" "${reason:-(no reason recorded)}"
    done
    echo "  → nightshift release <id>   (after you provide the dep)"
    echo "  → nightshift drop <id>      (discard / won't-do)"
    ;;
  release) repo="$(resolve_repo "")"; TODO="$HOME/.claude/hooks/devbrain-todo.sh"; [ -x "$TODO" ] || TODO="$DIR/todo.sh"
    ( cd "$repo" && "$TODO" release "$1" );;
  drop)    repo="$(resolve_repo "")"; TODO="$HOME/.claude/hooks/devbrain-todo.sh"; [ -x "$TODO" ] || TODO="$DIR/todo.sh"
    ( cd "$repo" && "$TODO" done "$1" ) && echo "dropped $1 (won't-do)";;
  approve|go) repo="$(resolve_repo "")"; TODO="$HOME/.claude/hooks/devbrain-todo.sh"; [ -x "$TODO" ] || TODO="$DIR/todo.sh"
    ( cd "$repo" && "$TODO" approve "$1" ) && echo "🟢 greenlit $1 — the fleet will pick it up and run it unattended (downloads/installs allowed)";;
  say)   tmux has-session -t "ns-w$1" 2>/dev/null || { echo "no tmux session ns-w$1 — say/attach work only with the --tmux backend" >&2; exit 1; }
         tmux send-keys -t "ns-w$1" -l "${*:2}"; tmux send-keys -t "ns-w$1" Enter; echo "→ w$1";;
  attach) tmux has-session -t "ns-w$1" 2>/dev/null || { echo "no tmux session ns-w$1 — attach works only with the --tmux backend (default is headless claude -p)" >&2; exit 1; }
          exec tmux attach -t "ns-w$1";;
  stop)
    repo="$(resolve_repo "${1:-}")"
    pkill -f "nightshift-orchestrate.sh${repo:+ --repo $repo}" 2>/dev/null && echo "stopped orchestrator" || echo "(orchestrator not running)"
    for s in $(tmux ls 2>/dev/null | awk -F: '/ns-w/{print $1}'); do tmux kill-session -t "$s" 2>/dev/null; done
    if [ -n "$repo" ]; then
      # The orchestrator's EXIT trap reaps in-flight turns, but a HARD kill (above)
      # skips it — so reap any headless `claude -p` still running via the per-worktree
      # turn.pid files it left behind. Without this they keep running detached.
      for f in "$repo"-w*/.nightshift/turn.pid; do
        [ -f "$f" ] || continue
        tp="$(cat "$f" 2>/dev/null)"; [ -n "$tp" ] && { pkill -P "$tp" 2>/dev/null; kill "$tp" 2>/dev/null; }
        rm -f "$f"
      done
      for p in emit http; do f="$repo/.nightshift/.$p.pid"; [ -f "$f" ] && kill "$(cat "$f")" 2>/dev/null; rm -f "$f"; done
      unregister_run "$repo"   # drop the queue dashboard's link to this now-stopped monitor
    fi
    echo "🌙 nightshift stopped."
    ;;
  *) sed -n '2,/REPO is remembered/p' "$SELF" | sed 's/^# \{0,1\}//';;
esac
