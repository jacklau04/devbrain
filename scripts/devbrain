#!/usr/bin/env bash
# devbrain — the one command. Every devbrain CLI tool is a subcommand here, so the
# shell surface is `devbrain <verb>` instead of a bag of differently-named scripts.
#
#   devbrain todo …          TODO queue (add·list·next·show·claim·review·hold·approve·done·release)
#   devbrain import …        seed/backfill the brain from existing Claude Code history
#   devbrain rebuild         rebuild the gbrain index from the markdown brain
#   devbrain flush [reason]  commit + push the data repo now (the on-demand flush)
#   devbrain nightshift …    autonomous overnight loop (experimental; only if installed)
#   devbrain version         print the installed devbrain version
#   devbrain help            this help
#
# Back-compat: the legacy names (devbrain-todo, devbrain-import, nightshift) keep
# working — install.sh still links them. Resolution is by ABSOLUTE path off this
# script's own dir (symlinks resolved), never relying on $PATH, so it behaves the
# same when run installed (~/.claude/hooks) or straight from a checkout (scripts/).
set -uo pipefail

# Resolve this script through any symlinks to find its real directory.
SELF="${BASH_SOURCE[0]}"
while [ -L "$SELF" ]; do
  d="$(cd -P "$(dirname "$SELF")" && pwd)"; SELF="$(readlink "$SELF")"
  case "$SELF" in /*) ;; *) SELF="$d/$SELF" ;; esac
done
DIR="$(cd -P "$(dirname "$SELF")" && pwd)"

# First existing path among candidates (installed name, then checkout names).
pick() { for c in "$@"; do [ -e "$c" ] && { printf '%s\n' "$c"; return 0; }; done; return 1; }
die()  { echo "devbrain: $*" >&2; exit 1; }

usage() { sed -n '2,12p' "$SELF" | sed 's/^# \{0,1\}//'; }

version() {
  local v; v="$(pick "$DIR/devbrain.version" "$DIR/../VERSION")" && cat "$v" || echo unknown
}

cmd="${1:-help}"; shift 2>/dev/null || true
case "$cmd" in
  todo)
    b="$(pick "$DIR/devbrain-todo.sh" "$DIR/todo.sh" "$DIR/../scripts/todo.sh")" || die "todo backend not found"
    exec "$b" "$@" ;;
  import)
    b="$(pick "$DIR/devbrain-import" "$DIR/import.py" "$DIR/../scripts/import.py")" || die "import backend not found"
    exec python3 "$b" "$@" ;;
  rebuild)
    b="$(pick "$DIR/devbrain-rebuild.sh" "$DIR/rebuild-brain.sh" "$DIR/../scripts/rebuild-brain.sh")" || die "rebuild backend not found"
    exec "$b" "$@" ;;
  flush)
    b="$(pick "$DIR/devbrain-flush.sh" "$DIR/flush.sh" "$DIR/../scripts/flush.sh")" || die "flush backend not found"
    exec "$b" "$@" ;;
  nightshift)
    b="$(pick "$HOME/.claude/nightshift/nightshift" "$DIR/../scripts/nightshift")" \
      || b="$(command -v nightshift 2>/dev/null)" \
      || die "nightshift not installed (opt in: ./setup --with nightshift)"
    exec "$b" "$@" ;;
  version|--version|-V) version ;;
  help|--help|-h)       usage ;;
  *) die "unknown command '$cmd' (try 'devbrain help')" ;;
esac
