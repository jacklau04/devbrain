<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Template. install.sh substitutes __FLUSH__ / __DATA__ / __LOG__ and writes
     the result to ~/Library/LaunchAgents/com.devbrain.flush.plist. -->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.devbrain.flush</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__FLUSH__</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>DEVBRAIN_DATA</key>
    <string>__DATA__</string>
  </dict>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__LOG__</string>
  <key>StandardErrorPath</key>
  <string>__LOG__</string>
</dict>
</plist>
