{
  "_note": "Prompt classifier rulebook. Copy to $DEVBRAIN_DATA/preferences/rulebook.json to override; anything omitted there falls back to this default. Order of passes: strip wrapper -> kind -> repeat -> payload.",

  "wrapper_strip_regex": "(?s)^\\s*<system_instruction>.*?</system_instruction>\\s*",
  "command_extract_regex": "(?s)^\\s*(?:<command-message>[^<]*</command-message>\\s*)?<command-name>\\s*(/[a-z][a-z0-9-]*[^<]*?)\\s*</command-name>\\s*",

  "system_prefixes": ["<system_instruction>", "<local-command-caveat>", "<command-", "<task-notification>"],
  "system_head_contains": ["Caveat: The messages below were generated"],
  "title_gen_prefixes": ["You are generating a short conversation title"],
  "nightshift_prefixes": ["PLANNING TURN:", "Check in on the nightshift", "Check on the nightshift"],
  "command_prefix": "/",

  "autonomous_cwd_regex": "/(?:nightshift|drain)/",
  "autonomous_worktree_regex": "-w\\d+$",

  "payload_voice_regex": "(?i)^\\s*(?:#[^\\n]*\\n\\s*)?(?:you are|you're)\\b",

  "repeat_signature_len": 200,
  "repeat_long_words": 200,
  "repeat_min_copies_short": 3,
  "repeat_min_copies_long": 2,

  "payload_min_words": 150,
  "payload_cross_project_min": 2
}
